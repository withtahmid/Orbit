        "typescript": "5.8.2"
    },
    "packageManager": "pnpm@9.7.0",
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    }
}
